# HelixAgent CI - Desktop Builder
# Electron, Tauri desktop apps with signing capabilities

FROM node:20-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies for Electron, Tauri, Playwright
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip \
    netcat-openbsd jq curl wget file \
    ca-certificates \
    libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libdbus-1-3 libxkbcommon0 \
    libatspi2.0-0 libxcomposite1 libxdamage1 libxext6 \
    libxfixes3 libxrandr2 libgbm1 libpango-1.0-0 \
    libcairo2 libasound2 \
    # For Tauri (Rust toolchain)
    curl gcc libwebkit2gtk-4.0-dev build-essential \
    libssl-dev libgtk-3-dev libayatana-appindicator3-dev librsvg2-dev \
    # For Electron code signing (Windows)
    osslsigncode wine64 \
    && rm -rf /var/lib/apt/lists/*

# Install Rust and Cargo (for Tauri)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Tauri CLI
RUN cargo install tauri-cli

# Install Electron Builder globally
RUN npm install -g electron-builder

# Playwright with browsers
RUN npx playwright install --with-deps chromium firefox webkit

WORKDIR /workspace

# Copy CI scripts
COPY ci/scripts/ci-entrypoint.sh /usr/local/bin/ci-entrypoint.sh
COPY ci/scripts/wait-for-services.sh /usr/local/bin/wait-for-services.sh
COPY ci/scripts/false-positive-check.sh /usr/local/bin/false-positive-check.sh
COPY ci/scripts/validate-artifacts.sh /usr/local/bin/validate-artifacts.sh
RUN chmod +x /usr/local/bin/ci-entrypoint.sh /usr/local/bin/wait-for-services.sh \
    /usr/local/bin/false-positive-check.sh /usr/local/bin/validate-artifacts.sh

ENV WORKSPACE=/workspace

ENTRYPOINT ["/usr/local/bin/ci-entrypoint.sh"]