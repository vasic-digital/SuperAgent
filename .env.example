# HelixAgent Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR ACTUAL VALUES
# NEVER COMMIT .env FILES WITH REAL API KEYS

# =============================================================================
# CRITICAL SECURITY WARNING
# =============================================================================
# This file contains placeholders only. Create a .env file with real values.
# The .env file is gitignored and will NEVER be committed.
# API keys are sensitive - treat them like passwords!

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=7061
GIN_MODE=release
JWT_SECRET=your-secret-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=helixagent
DB_PASSWORD=helixagent123
DB_NAME=helixagent_db
DB_SSL_MODE=disable

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=helixagent123
REDIS_DB=0

# =============================================================================
# HELIXMEMORY CONFIGURATION (Unified Cognee + Mem0 + Letta)
# =============================================================================

# Memory System Mode: "local" (containers) or "cloud" (API)
HELIX_MEMORY_MODE=local

# --- LOCAL MODE (Containers) ---
# These endpoints are used when HELIX_MEMORY_MODE=local
HELIX_MEMORY_COGNEE_ENDPOINT=http://localhost:8000
HELIX_MEMORY_MEM0_ENDPOINT=http://localhost:8001
HELIX_MEMORY_LETTA_ENDPOINT=http://localhost:8283
HELIX_MEMORY_GRAPHITI_ENDPOINT=http://localhost:8003

# --- CLOUD MODE (API Fallback) ---
# These are used when HELIX_MEMORY_MODE=cloud or local containers fail
# Get API keys from:
# - Cognee: https://platform.cognee.ai
# - Mem0: https://app.mem0.ai
# - Letta: https://docs.letta.com/guides/build-with-letta/quickstart
HELIX_MEMORY_COGNEE_API_KEY=your-cognee-api-key-here
HELIX_MEMORY_MEM0_API_KEY=your-mem0-api-key-here
HELIX_MEMORY_LETTA_API_KEY=your-letta-api-key-here

# Cloud API Endpoints (leave empty to use defaults)
HELIX_MEMORY_COGNEE_CLOUD_ENDPOINT=https://api.cognee.ai
HELIX_MEMORY_MEM0_CLOUD_ENDPOINT=https://api.mem0.ai
HELIX_MEMORY_LETTA_CLOUD_ENDPOINT=https://api.letta.com

# --- INFRASTRUCTURE ---
HELIX_MEMORY_QDRANT_ENDPOINT=http://localhost:6333
HELIX_MEMORY_NEO4J_ENDPOINT=bolt://localhost:7687
HELIX_MEMORY_NEO4J_USER=neo4j
HELIX_MEMORY_NEO4J_PASSWORD=helixmemory
HELIX_MEMORY_REDIS_ENDPOINT=localhost:6379
HELIX_MEMORY_REDIS_PASSWORD=

# --- FUSION ENGINE ---
HELIX_MEMORY_FUSION_DEDUP_THRESHOLD=0.92
HELIX_MEMORY_DEFAULT_TOP_K=10
HELIX_MEMORY_REQUEST_TIMEOUT=10s

# --- CONSOLIDATION (Sleep-Time Compute) ---
HELIX_MEMORY_CONSOLIDATION_ENABLED=true
HELIX_MEMORY_CONSOLIDATION_INTERVAL=30m

# --- CIRCUIT BREAKER ---
HELIX_MEMORY_CIRCUIT_BREAKER_THRESHOLD=5
HELIX_MEMORY_CIRCUIT_BREAKER_TIMEOUT=30s

# =============================================================================
# LLM PROVIDER API KEYS (20+ Providers Supported)
# =============================================================================

# OpenAI (Recommended)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_ORG_ID=

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Groq (Fast Inference)
GROQ_API_KEY=gsk-your-groq-key

# Mistral
MISTRAL_API_KEY=your-mistral-key

# Cohere
COHERE_API_KEY=your-cohere-key

# Perplexity
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# Together AI
TOGETHER_API_KEY=your-together-key

# Fireworks
FIREWORKS_API_KEY=your-fireworks-key

# Cerebras
CEREBRAS_API_KEY=your-cerebras-key

# xAI (Grok)
XAI_API_KEY=your-xai-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_VERSION=2024-02-01

# AI21 Labs
AI21_API_KEY=your-ai21-key

# OpenRouter
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Cloudflare Workers AI
CLOUDFLARE_API_KEY=your-cloudflare-key
CLOUDFLARE_ACCOUNT_ID=your-account-id

# Replicate
REPLICATE_API_TOKEN=r8-your-replicate-token

# NVIDIA NIM
NVIDIA_NIM_API_KEY=nvapi-your-nvidia-key

# Novita
NOVITA_API_KEY=your-novita-key

# Anyscale
ANYSCALE_API_KEY=your-anyscale-key

# =============================================================================
# SEARCH PROVIDERS (Web Search Integration)
# =============================================================================
TAVILY_API_KEY=tvly-your-tavily-key
PERPLEXITY_API_KEY=pplx-your-perplexity-key
EXA_API_KEY=your-exa-key
SERPAPI_API_KEY=your-serpapi-key
BING_API_KEY=your-bing-key

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SENTRY_DSN=

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_DEBATE_ENABLED=true
FEATURE_ENSEMBLE_ENABLED=true
FEATURE_MCP_ENABLED=true
FEATURE_RAG_ENABLED=true
FEATURE_VISION_ENABLED=true

# =============================================================================
# SECURITY
# =============================================================================
SECURITY_SCAN_ENABLED=true
RATE_LIMIT_RPM=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# DEVELOPMENT (Only for local development)
# =============================================================================
DEBUG_ENABLED=false
LOG_LEVEL=info
MOCK_LLM_RESPONSES=false
