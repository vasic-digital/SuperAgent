# HelixAgent Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR ACTUAL VALUES
# NEVER COMMIT .env FILES WITH REAL API KEYS
# =============================================================================

# =============================================================================
# CRITICAL SECURITY WARNING
# =============================================================================
# This file contains placeholders ONLY. Create a .env file with real values.
# The .env file is gitignored and will NEVER be committed.
# API keys are sensitive - treat them like passwords!
# 
# To set up:
#   cp .env.example .env
#   # Edit .env and fill in your values
# =============================================================================

# =============================================================================
# HELIXMEMORY CONFIGURATION (Unified Cognee + Mem0 + Letta)
# =============================================================================

# Memory System Mode: "local" (containers) or "cloud" (API)
# - "local": Runs all services in Docker containers (default, recommended)
# - "cloud": Uses cloud API endpoints (requires API keys)
#
# IMPORTANT: Cognee requires a paid subscription for cloud access.
# If you don't have COGNEE_API_KEY, leave it empty and HelixMemory will
# automatically use the local Cognee container.
HELIX_MEMORY_MODE=local

# --- LOCAL MODE (Containers) - DEFAULT RECOMMENDED ---
# These endpoints are used when HELIX_MEMORY_MODE=local
# All services run in Docker containers via docker-compose.memory.yml
HELIX_MEMORY_COGNEE_ENDPOINT=http://localhost:8000
HELIX_MEMORY_MEM0_ENDPOINT=http://localhost:8001
HELIX_MEMORY_LETTA_ENDPOINT=http://localhost:8283
HELIX_MEMORY_GRAPHITI_ENDPOINT=http://localhost:8003

# --- CLOUD MODE (API) - Only if you have API keys ---
# Cognee: https://platform.cognee.ai - REQUIRES PAID SUBSCRIPTION
# Mem0: https://app.mem0.ai - Free tier available
# Letta: https://docs.letta.com - Free tier available
#
# IMPORTANT: If COGNEE_API_KEY is empty, local container will be used
# even if HELIX_MEMORY_MODE=cloud for other services

# Cloud API Keys (leave empty to use local containers)
HELIX_MEMORY_COGNEE_API_KEY=              # Cognee PAID - leave empty for local
HELIX_MEMORY_MEM0_API_KEY=your-mem0-key   # Mem0 - get from app.mem0.ai
HELIX_MEMORY_LETTA_API_KEY=your-letta-key # Letta - get from docs.letta.com

# Cloud Endpoints (only used when API keys are provided)
# These are the defaults - only change if using custom endpoints
HELIX_MEMORY_COGNEE_CLOUD_ENDPOINT=https://api.cognee.ai
HELIX_MEMORY_MEM0_CLOUD_ENDPOINT=https://api.mem0.ai
HELIX_MEMORY_LETTA_CLOUD_ENDPOINT=https://api.letta.com

# --- INFRASTRUCTURE (for local mode) ---
HELIX_MEMORY_QDRANT_ENDPOINT=http://localhost:6333
HELIX_MEMORY_NEO4J_ENDPOINT=bolt://localhost:7687
HELIX_MEMORY_NEO4J_USER=neo4j
HELIX_MEMORY_NEO4J_PASSWORD=helixmemory
HELIX_MEMORY_REDIS_ENDPOINT=localhost:6379
HELIX_MEMORY_REDIS_PASSWORD=

# --- FUSION ENGINE ---
HELIX_MEMORY_FUSION_DEDUP_THRESHOLD=0.92
HELIX_MEMORY_DEFAULT_TOP_K=10
HELIX_MEMORY_REQUEST_TIMEOUT=10s

# --- CONSOLIDATION (Sleep-Time Compute) ---
HELIX_MEMORY_CONSOLIDATION_ENABLED=true
HELIX_MEMORY_CONSOLIDATION_INTERVAL=30m

# --- CIRCUIT BREAKER ---
HELIX_MEMORY_CIRCUIT_BREAKER_THRESHOLD=5
HELIX_MEMORY_CIRCUIT_BREAKER_TIMEOUT=30s

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# OPTION 1: Local Mode (Recommended - Free)
# ------------------------------------------
# 1. Check hardware: ./scripts/check_memory_hardware.sh
# 2. Start services: docker-compose -f docker-compose.memory.yml up -d
# 3. All services run locally, no API keys needed for Cognee
# 4. Optional: Add MEM0_API_KEY and LETTA_API_KEY if you want cloud backup
#
# OPTION 2: Cloud Mode (Paid for Cognee)
# --------------------------------------
# 1. Get API keys:
#    - Cognee: https://platform.cognee.ai (PAID subscription required)
#    - Mem0: https://app.mem0.ai (free tier available)
#    - Letta: https://docs.letta.com (free tier available)
# 2. Set HELIX_MEMORY_MODE=cloud
# 3. Fill in all HELIX_MEMORY_*_API_KEY values
# 4. Services will use cloud APIs instead of local containers
#
# OPTION 3: Hybrid Mode (Mixed)
# -----------------------------
# Set HELIX_MEMORY_MODE=local
# Provide API keys only for services you want in cloud
# Missing API keys will use local containers automatically
#
# =============================================================================

# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================
# At least one provider is required for HelixAgent to function

# OpenAI (Recommended)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Groq (Fast)
GROQ_API_KEY=gsk-your-groq-key

# Mistral
MISTRAL_API_KEY=your-mistral-key

# Cohere
COHERE_API_KEY=your-cohere-key

# Perplexity
PERPLEXITY_API_KEY=pplx-your-perplexity-key

# Google Gemini
GEMINI_API_KEY=your-gemini-key

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=helixagent
DB_PASSWORD=helixagent123
DB_NAME=helixagent_db
DB_SSL_MODE=disable

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=helixagent123
REDIS_DB=0

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=7061
GIN_MODE=release
JWT_SECRET=your-secret-key-here

# =============================================================================
# SEARCH PROVIDERS
# =============================================================================
TAVILY_API_KEY=tvly-your-tavily-key
PERPLEXITY_API_KEY=pplx-your-perplexity-key
EXA_API_KEY=your-exa-key

# =============================================================================
# MONITORING
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_DEBATE_ENABLED=true
FEATURE_ENSEMBLE_ENABLED=true
FEATURE_MCP_ENABLED=true
FEATURE_RAG_ENABLED=true
FEATURE_VISION_ENABLED=true

# =============================================================================
# SECURITY
# =============================================================================
SECURITY_SCAN_ENABLED=true
RATE_LIMIT_RPM=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# DEVELOPMENT
# =============================================================================
DEBUG_ENABLED=false
LOG_LEVEL=info
