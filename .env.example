# HelixAgent Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials
# ============================================================

# Server Configuration
PORT=7061
GIN_MODE=debug
JWT_SECRET=change-this-to-a-secure-random-string

# Profiling (optional - exposes /debug/pprof endpoints for performance profiling)
# ENABLE_PPROF=false

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=helixagent
DB_PASSWORD=helixagent123
DB_NAME=helixagent_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# LLM Provider API Keys (optional - for API key providers)
# CLAUDE_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_ACCOUNT_ID=
# GEMINI_USE_OAUTH_CREDENTIALS=false
# GEMINI_PREFERRED_METHOD=auto  # auto, api, cli, acp
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
# ZAI_API_KEY=
# CEREBRAS_API_KEY=
# PUBLICAI_API_KEY=
# CHUTES_API_KEY=
# COHERE_API_KEY=
# GITHUB_MODELS_API_KEY=
# OLLAMA_ENABLED=false
# OLLAMA_BASE_URL=http://localhost:11434

# OAuth2 Flags (enable CLI proxy for OAuth providers)
# CLAUDE_CODE_USE_OAUTH_CREDENTIALS=true
# QWEN_CODE_USE_OAUTH_CREDENTIALS=true

# Zen/OpenCode API Key (optional - CLI proxy for free mode)
# OPENCODE_API_KEY=

# CLI Agent Detection (optional - set to enable auto-detection of CLI client)
# CRUSH_CLI=                          # Path to Crush CLI binary (triggers Crush client detection)
# CRUSH_VERSION=                      # Crush version override for client identification
# HELIXCODE=                          # HelixCode CLI detection marker (any non-empty value)
# HELIXCODE_VERSION=                  # HelixCode version override for client identification
# KILOCODE=                           # KiloCode CLI detection marker (any non-empty value)
# KILOCODE_VERSION=                   # KiloCode version override for client identification

# Cognee (optional - disabled by default, Mem0 is primary memory provider)
# COGNEE_ENABLED=false
# COGNEE_AUTH_EMAIL=admin@helixagent.ai
# COGNEE_AUTH_PASSWORD=HelixAgentPass123

# Constitution Watcher & SpecKit Configuration
# ============================================================
# Constitution auto-update on project changes (new modules, docs, structure)
# CONSTITUTION_WATCHER_ENABLED=false
# CONSTITUTION_WATCHER_CHECK_INTERVAL=5m

# Project root path for Constitution monitoring (defaults to current working directory)
# PROJECT_ROOT=/path/to/project

# SpecKit 7-phase development flow (auto-activated for big changes/refactoring)
# Phase caching enabled by default, stored in .speckit/cache/
# Auto-activation triggers: big_creation, whole_functionality, refactoring
# No manual configuration needed - automatically activated based on work granularity

# BigData Integration Configuration
# ============================================================
# Enable/disable components (defaults shown)
BIGDATA_ENABLE_INFINITE_CONTEXT=true
BIGDATA_ENABLE_DISTRIBUTED_MEMORY=false
BIGDATA_ENABLE_KNOWLEDGE_GRAPH=false
BIGDATA_ENABLE_ANALYTICS=false
BIGDATA_ENABLE_CROSS_LEARNING=true

# Kafka configuration
BIGDATA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
BIGDATA_KAFKA_CONSUMER_GROUP=helixagent-bigdata

# ClickHouse configuration
BIGDATA_CLICKHOUSE_HOST=localhost
BIGDATA_CLICKHOUSE_PORT=8123
BIGDATA_CLICKHOUSE_DATABASE=helixagent
BIGDATA_CLICKHOUSE_USER=default
BIGDATA_CLICKHOUSE_PASSWORD=

# Neo4j configuration
BIGDATA_NEO4J_URI=bolt://localhost:7687
BIGDATA_NEO4J_USERNAME=neo4j
BIGDATA_NEO4J_PASSWORD=password
BIGDATA_NEO4J_DATABASE=neo4j

# Context engine configuration
BIGDATA_CONTEXT_CACHE_SIZE=1000
BIGDATA_CONTEXT_CACHE_TTL=24h
BIGDATA_CONTEXT_COMPRESSION_TYPE=gzip

# Learning configuration
BIGDATA_LEARNING_MIN_CONFIDENCE=0.7
BIGDATA_LEARNING_MIN_FREQUENCY=3

# Service Configuration Overrides
# Use SVC_<SERVICE>_<FIELD> to override service endpoints
# Example: SVC_POSTGRESQL_HOST=remote-db.example.com
# See configs/development.yaml for available services