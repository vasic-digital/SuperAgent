# HelixAgent Challenges - API Keys Configuration
# ================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env with real keys!
# ================================================

# ===========================================
# Primary HelixAgent LLM Providers
# ===========================================

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxx

# Google Gemini
GEMINI_API_KEY=AIzaSyxxxxx

# OpenRouter (Multi-provider gateway)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Qwen (Alibaba)
QWEN_API_KEY=sk-xxxxx

# Z.AI
ZAI_API_KEY=xxxxx

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

# ===========================================
# Tier 2: High-Quality Specialized Providers
# ===========================================

# xAI (Grok models)
XAI_API_KEY=xai-xxxxx
# Alternative env var:
# GROK_API_KEY=xai-xxxxx

# Cohere (Command models, RAG support)
COHERE_API_KEY=xxxxx
# Alternative env var:
# CO_API_KEY=xxxxx

# Perplexity (Search-focused LLM with citations)
PERPLEXITY_API_KEY=pplx-xxxxx
# Alternative env var:
# PPLX_API_KEY=pplx-xxxxx

# ===========================================
# Tier 3: Fast Inference Providers
# ===========================================

# Groq (Fast inference, Llama models)
GROQ_API_KEY=gsk_xxxxx

# Cerebras
CEREBRAS_API_KEY=csk-xxxxx

# ===========================================
# Tier 4: Alternative Providers
# ===========================================

# Together AI
TOGETHER_API_KEY=xxxxx
# Alternative env var:
# TOGETHERAI_API_KEY=xxxxx

# Fireworks AI
FIREWORKS_API_KEY=fw_xxxxx

# ===========================================
# Tier 5: Specialized Providers
# ===========================================

# AI21 Labs (Jamba models, 256K context)
AI21_API_KEY=xxxxx

# Replicate (Async predictions, open models)
REPLICATE_API_KEY=r8_xxxxx

# HuggingFace (Inference API)
HUGGINGFACE_API_KEY=hf_xxxxx

# Mistral AI Studio
MISTRAL_API_KEY=xxxxx

# Codestral
CODESTRAL_API_KEY=xxxxx

# ===========================================
# Tier 6: Regional/Other Providers
# ===========================================

# Nvidia
NVIDIA_API_KEY=nvapi-xxxxx

# Chutes
CHUTES_API_KEY=cpk_xxxxx

# SiliconFlow
SILICONFLOW_API_KEY=sk-xxxxx

# Kimi (Moonshot)
KIMI_API_KEY=sk-kimi-xxxxx

# Vercel AI Gateway
VERCEL_AI_GATEWAY_KEY=vck_xxxxx

# Cloudflare Workers AI
CLOUDFLARE_WORKERS_AI_KEY=xxxxx

# Baseten
BASETEN_API_KEY=xxxxx

# Novita AI
NOVITA_AI_KEY=sk_xxxxx

# Upstage AI
UPSTAGE_AI_KEY=up_xxxxx

# NLP Cloud
NLP_CLOUD_KEY=xxxxx

# Modal
MODAL_TOKEN_ID=ak-xxxxx
MODAL_TOKEN_SECRET=as-xxxxx

# Inference
INFERENCE_API_KEY=inference-xxxxx

# ===========================================
# Challenge Configuration
# ===========================================

# Debate Group Settings
DEBATE_GROUP_SIZE=5
DEBATE_FALLBACKS_PER_MEMBER=2

# Verification Settings
VERIFICATION_TIMEOUT_SECONDS=30
VERIFICATION_RETRY_COUNT=3

# Logging
LOG_LEVEL=INFO
LOG_API_REQUESTS=true
LOG_API_RESPONSES=true

# Results Storage
RESULTS_RETENTION_DAYS=30

# ===========================================
# LLMsVerifier Integration
# ===========================================

# Path to LLMsVerifier binary
LLMSVERIFIER_PATH=../LLMsVerifier/llm-verifier

# LLMsVerifier config
LLMSVERIFIER_CONFIG=../LLMsVerifier/config.yaml
