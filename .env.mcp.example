# =============================================================================
# MCP Services Environment Variables
# =============================================================================
# Copy this file to .env.mcp and fill in your API keys/tokens
# Then run: source .env.mcp
#
# Each MCP category requires specific environment variables.
# MCPs will only be enabled if their required variables are set.
# =============================================================================

# =============================================================================
# LOCAL SERVICES (Start with: ./scripts/mcp/start-mcp-services.sh --all)
# =============================================================================

# Redis MCP
REDIS_URL=redis://:helixagent123@localhost:16379
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=helixagent123

# MongoDB MCP
MONGODB_URI=mongodb://helixagent:helixagent123@localhost:27017/helixagent?authSource=admin
MONGODB_HOST=localhost
MONGODB_PORT=27017

# PostgreSQL MCP
POSTGRES_URL=postgresql://helixagent:helixagent123@localhost:15432/helixagent_db
POSTGRES_HOST=localhost
POSTGRES_PORT=15432

# MySQL MCP
MYSQL_URL=mysql://helixagent:helixagent123@localhost:3306/helixagent
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Elasticsearch MCP
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_HOST=localhost

# =============================================================================
# VECTOR DATABASES (Start with: ./scripts/mcp/start-mcp-services.sh --vectors)
# =============================================================================

# Qdrant MCP
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost

# Chroma MCP
CHROMA_URL=http://localhost:8000
CHROMA_HOST=localhost

# Pinecone MCP (Cloud service)
# Get API key from: https://app.pinecone.io/
PINECONE_API_KEY=

# Weaviate MCP
WEAVIATE_URL=http://localhost:8080

# =============================================================================
# DEVELOPMENT PLATFORMS
# =============================================================================

# GitHub MCP
# Get token from: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=

# GitLab MCP
# Get token from: https://gitlab.com/-/profile/personal_access_tokens
# Required scopes: api, read_api
GITLAB_TOKEN=

# Sentry MCP
# Get token from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# =============================================================================
# COMMUNICATION & COLLABORATION
# =============================================================================

# Slack MCP
# Create app at: https://api.slack.com/apps
# Required scopes: channels:history, channels:read, chat:write, users:read
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# Discord MCP
# Create bot at: https://discord.com/developers/applications
DISCORD_TOKEN=

# Telegram MCP
# Get token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# =============================================================================
# PRODUCTIVITY & PROJECT MANAGEMENT
# =============================================================================

# Notion MCP
# Get token from: https://www.notion.so/my-integrations
NOTION_API_KEY=

# Linear MCP
# Get API key from: Linear Settings → API
LINEAR_API_KEY=

# Jira MCP
# Get token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=

# Asana MCP
# Get token from: https://app.asana.com/0/developer-console
ASANA_ACCESS_TOKEN=

# Trello MCP
# Get keys from: https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_API_TOKEN=

# Todoist MCP
# Get token from: https://todoist.com/app/settings/integrations
TODOIST_API_TOKEN=

# Monday MCP
# Get token from: https://monday.com/developers/apps
MONDAY_API_TOKEN=

# =============================================================================
# SEARCH & AI
# =============================================================================

# Brave Search MCP
# Get API key from: https://brave.com/search/api/
BRAVE_API_KEY=

# Exa MCP
# Get API key from: https://exa.ai/
EXA_API_KEY=

# Tavily MCP
# Get API key from: https://tavily.com/
TAVILY_API_KEY=

# Perplexity MCP
# Get API key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Kagi MCP
# Get API key from: https://kagi.com/settings?p=api
KAGI_API_KEY=

# OpenAI MCP
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# CLOUD PROVIDERS
# =============================================================================

# Cloudflare MCP
# Get token from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Vercel MCP
# Get token from: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Heroku MCP
# Get API key from: https://dashboard.heroku.com/account
HEROKU_API_KEY=

# AWS MCP
# Get credentials from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP MCP
# Set path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Supabase MCP
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_KEY=

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials

# Google Drive / Calendar / Gmail MCPs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Maps MCP
# Get API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# YouTube MCP
# Get API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Datadog MCP
# Get keys from: https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=
DD_APP_KEY=

# Grafana MCP
# Create API key in Grafana: Configuration → API Keys
GRAFANA_URL=http://localhost:3000
GRAFANA_TOKEN=

# Prometheus MCP
PROMETHEUS_URL=http://localhost:9090

# =============================================================================
# FINANCE & BUSINESS
# =============================================================================

# Stripe MCP
# Get API key from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=

# HubSpot MCP
# Get token from: https://app.hubspot.com/private-apps/
HUBSPOT_ACCESS_TOKEN=

# Zendesk MCP
# Get token from: Admin → Channels → API
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_TOKEN=

# =============================================================================
# BROWSER & WEB
# =============================================================================

# Browserbase MCP
# Get API key from: https://browserbase.com/
BROWSERBASE_API_KEY=

# Browserless (for Puppeteer)
PUPPETEER_BROWSER_WS_ENDPOINT=ws://localhost:3333

# =============================================================================
# DESIGN
# =============================================================================

# Figma MCP
# Get token from: https://www.figma.com/developers/api#access-tokens
FIGMA_API_KEY=

# =============================================================================
# NOTES & KNOWLEDGE
# =============================================================================

# Obsidian MCP
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian

# =============================================================================
# DEVOPS
# =============================================================================

# Kubernetes MCP
KUBECONFIG=~/.kube/config
