# ============================================================
# MCP Environment Variables
# ============================================================
# Copy this file to .env.mcps and fill in your credentials
# Then source it: source .env.mcps
# ============================================================

# === VERSION CONTROL ===

# GitHub - https://github.com/settings/tokens
# Scopes needed: repo, read:org, read:user
GITHUB_TOKEN=

# GitLab - Settings → Access Tokens
# Scopes needed: api, read_repository
GITLAB_TOKEN=

# === COMMUNICATION ===

# Slack - https://api.slack.com/apps
# Bot Token Scopes: channels:history, channels:read, chat:write, users:read
SLACK_BOT_TOKEN=
SLACK_ENABLE_SEND_MESSAGE=false
# SLACK_ALLOWED_CHANNELS=C12345678,C87654321

# Discord - https://discord.com/developers/applications
# Enable MESSAGE CONTENT INTENT in Bot settings
DISCORD_BOT_TOKEN=

# Telegram - https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === PROJECT MANAGEMENT ===

# Linear - Settings → API → Personal API Keys
LINEAR_ACCESS_TOKEN=

# Notion - https://www.notion.so/my-integrations
# Remember to share pages with your integration
NOTION_API_KEY=

# Jira - https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# Trello - https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=
# TRELLO_BOARD_ID=  # Optional default board

# === SEARCH & AI ===

# Brave Search - https://brave.com/search/api/
BRAVE_API_KEY=

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# YouTube - https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Twitter/X - https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# === CLOUD PROVIDERS ===

# AWS - https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# GCP - https://console.cloud.google.com/iam-admin/serviceaccounts
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Vercel - https://vercel.com/account/tokens
VERCEL_TOKEN=

# Cloudflare - https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# === DATABASES ===

# MongoDB - Connection string for local or Atlas
# MDB_MCP_CONNECTION_STRING=mongodb://localhost:27017/mydb
# MDB_MCP_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/mydb
MDB_MCP_CONNECTION_STRING=

# For MongoDB Atlas management (optional)
MDB_MCP_ATLAS_CLIENT_ID=
MDB_MCP_ATLAS_CLIENT_SECRET=

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Elasticsearch - http://localhost:9200
ES_URL=http://localhost:9200
ES_API_KEY=

# Qdrant (optional if authentication enabled)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# === HELIXAGENT ===

# HelixAgent API (optional for local development)
HELIXAGENT_API_KEY=
